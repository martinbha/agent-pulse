#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
APP_NAME="Agent Pulse"
BUNDLE_ID="dev.martinbhatta.agent-pulse"
DIST_DIR="$ROOT_DIR/dist"
APP_DIR="$DIST_DIR/$APP_NAME.app"
CONTENTS_DIR="$APP_DIR/Contents"
MACOS_DIR="$CONTENTS_DIR/MacOS"
RESOURCES_DIR="$CONTENTS_DIR/Resources"
APP_ICON_SOURCE="$ROOT_DIR/Sources/AgentPulseCore/Resources/agent-pulse-icon.svg"
MENU_BAR_ICON_SOURCE="$ROOT_DIR/Sources/AgentPulseCore/Resources/agent-pulse-menubar.svg"
APP_ICON_NAME="AgentPulse"
BUNDLE_VERSION="3"
APP_VERSION="$(tr -d '[:space:]' < "$ROOT_DIR/VERSION")"

if [[ ! "$APP_VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+([.-][0-9A-Za-z.-]+)?$ ]]; then
  echo "Invalid app version in $ROOT_DIR/VERSION: $APP_VERSION" >&2
  exit 1
fi

cd "$ROOT_DIR"
swift build -c release

BIN_DIR="$(swift build -c release --show-bin-path)"
BIN_PATH="$BIN_DIR/agent-pulse"
NOTIFIER_BIN_PATH="$BIN_DIR/agent-pulse-notifier"

rm -rf "$APP_DIR"
mkdir -p "$MACOS_DIR" "$RESOURCES_DIR"
cp "$BIN_PATH" "$MACOS_DIR/$APP_NAME"
cp "$ROOT_DIR/Sources/AgentPulseCore/Resources/working-verbs.txt" "$RESOURCES_DIR/working-verbs.txt"
cp "$ROOT_DIR/Sources/AgentPulseCore/Resources/KeepCalm-Medium.ttf" "$RESOURCES_DIR/KeepCalm-Medium.ttf"
cp "$APP_ICON_SOURCE" "$RESOURCES_DIR/agent-pulse-icon.svg"
cp "$MENU_BAR_ICON_SOURCE" "$RESOURCES_DIR/agent-pulse-menubar.svg"

ICONSET_PARENT="$(mktemp -d)"
trap 'rm -rf "$ICONSET_PARENT"' EXIT

render_icns() {
  local source="$1"
  local output="$2"
  local iconset_dir
  iconset_dir="$(mktemp -d "$ICONSET_PARENT/XXXXXX")/icon.iconset"
  mkdir -p "$iconset_dir"

  local points
  for points in 16 32 128 256 512; do
    sips -s format png -z "$points" "$points" "$source" \
      --out "$iconset_dir/icon_${points}x${points}.png" >/dev/null
    sips -s format png -z "$((points * 2))" "$((points * 2))" "$source" \
      --out "$iconset_dir/icon_${points}x${points}@2x.png" >/dev/null
  done

  iconutil -c icns "$iconset_dir" -o "$output"
}

render_icns "$APP_ICON_SOURCE" "$RESOURCES_DIR/$APP_ICON_NAME.icns"

write_info_plist() {
  local output="$1"
  local name="$2"
  local bundle_id="$3"
  local icon_name="$4"

  cat > "$output" <<PLIST
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleExecutable</key>
  <string>$name</string>
  <key>CFBundleIdentifier</key>
  <string>$bundle_id</string>
  <key>CFBundleIconFile</key>
  <string>$icon_name</string>
  <key>CFBundleName</key>
  <string>$name</string>
  <key>CFBundleDisplayName</key>
  <string>$name</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>$APP_VERSION</string>
  <key>CFBundleVersion</key>
  <string>$BUNDLE_VERSION</string>
  <key>LSMinimumSystemVersion</key>
  <string>14.0</string>
  <key>LSUIElement</key>
  <true/>
  <key>NSHighResolutionCapable</key>
  <true/>
</dict>
</plist>
PLIST
}

# Per-agent notifier helpers: each wraps the shared notifier binary in its own
# bundle so notifications it posts carry that agent's logo as the sender icon.
# Helper names must stay in sync with AgentKind.notifierHelperName in
# Sources/AgentPulseCore/Notifications/AgentNotificationService.swift.
build_notifier_helper() {
  local name="$1"
  local bundle_id="$2"
  local icon_source="$3"
  local contents="$CONTENTS_DIR/Helpers/$name.app/Contents"

  mkdir -p "$contents/MacOS" "$contents/Resources"
  cp "$NOTIFIER_BIN_PATH" "$contents/MacOS/$name"
  render_icns "$icon_source" "$contents/Resources/AgentIcon.icns"
  write_info_plist "$contents/Info.plist" "$name" "$bundle_id" "AgentIcon"
}

build_notifier_helper "Agent Pulse Claude" "$BUNDLE_ID.claude" \
  "$ROOT_DIR/Sources/AgentPulseCore/Resources/claude-logo.svg"
build_notifier_helper "Agent Pulse Codex" "$BUNDLE_ID.codex" \
  "$ROOT_DIR/Sources/AgentPulseCore/Resources/codex-logo.svg"

write_info_plist "$CONTENTS_DIR/Info.plist" "$APP_NAME" "$BUNDLE_ID" "$APP_ICON_NAME"

codesign --force --deep --sign - "$APP_DIR" >/dev/null

echo "$APP_DIR"
